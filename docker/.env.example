# 既定の起動設定（`docker compose up -d` で使用。WordPress 6.8 / PHP 8.3 安定版）。
# 別の WordPress / PHP 組み合わせは env/ の env ファイルを指定する:
#   docker compose --env-file env/wp7.0-php8.4.env up -d
# 資格情報などを変えたい場合はこのファイルを編集する（.env.example がテンプレート）。

COMPOSE_PROJECT_NAME=cocoon-wp68-php83
WP_IMAGE=wordpress:6.8-php8.3-apache
WEB_PORT=8085
DB_PORT=3085
PMA_PORT=8185

# 共通の資格情報 / 設定
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_TABLE_PREFIX=wp_
MYSQL_ROOT_PASSWORD=rootpassword
WORDPRESS_DEBUG=1
