# =============================================================================
# 配布ZIP（git archive / GitHub Download ZIP）から除外するファイル
# 開発者の git clone / git pull や GitHub Actions CI には影響しません
# =============================================================================

# テスト関連
/tests/                export-ignore
/phpunit.xml           export-ignore
/.phpunit.cache/       export-ignore

# CI / 開発ツール設定
/.github/              export-ignore
/.vscode/              export-ignore
/.gitattributes        export-ignore
/.gitignore            export-ignore

# Composer（本番テーマには不要）
/composer.json         export-ignore
/composer.lock         export-ignore

# 翻訳ワークフロー用開発スクリプト
/scripts/              export-ignore

# 本番テーマに不要なリソース（ZIPサイズ削減用）
/webfonts/fontawesome5/js/       export-ignore
/webfonts/fontawesome5/metadata/ export-ignore
/webfonts/fontawesome5/svgs/     export-ignore
/webfonts/fontawesome5/sprites/  export-ignore
/webfonts/fontawesome5/scss/     export-ignore
/webfonts/fontawesome5/less/     export-ignore

# NPMパッケージ管理（本番テーマには不要）
/package.json             export-ignore
/package-lock.json        export-ignore
/blocks/package.json      export-ignore
/blocks/package-lock.json export-ignore
